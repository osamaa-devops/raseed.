{
  "name": "raseed-workspace",
  "private": true,
  "version": "1.0.0-rc.1",
  "description": "Raseed offline-ready desktop POS for clothing shops.",
  "author": "OpenAI Codex",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-web.cjs",
    "local:check": "node scripts/local-check.cjs",
    "demo:check-users": "node scripts/check-demo-users.cjs",
    "local:setup": "node scripts/local-setup.cjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "dev:backend": "npm --prefix backend run dev",
    "backend:start:dev": "npm --prefix backend run start:dev",
    "backend:build": "npm --prefix backend run build",
    "db:migrate": "npm --prefix backend run prisma:migrate",
    "db:seed": "npm --prefix backend run prisma:seed",
    "db:studio": "npm --prefix backend run prisma:studio",
    "desktop:dev": "node scripts/dev-desktop.cjs",
    "desktop:build": "node scripts/build-desktop.cjs",
    "desktop:package": "electron-builder"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "exceljs": "^3.4.0",
    "helmet": "^8.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.raseed.pos",
    "productName": "Raseed",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**",
      "scripts/**",
      "frontend/dist/**",
      "frontend/.env.example",
      "frontend/.env.production.example",
      "backend/dist/**",
      "backend/prisma/**",
      "backend/.env.example",
      "backend/.env.production.example",
      "node_modules/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/.prisma/**",
      "**/node_modules/@prisma/engines/**"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "artifactName": "RaseedSetup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
