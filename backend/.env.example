NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Local PostgreSQL example for development and desktop runs.
# database: raseed_dev
# user: raseed
# password: raseed_password
DATABASE_URL=postgresql://raseed:raseed_password@localhost:5432/raseed_dev?schema=public
JWT_SECRET=replace-with-a-long-random-development-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
AUTH_COOKIE_NAME=raseed_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
UPLOAD_MAX_MB=10
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
LOG_LEVEL=log,debug,warn,error
# Optional local desktop runtime overrides. Electron normally sets these for you.
# RASEED_DATA_DIR=./runtime
# RASEED_LOGS_DIR=./runtime/logs
# RASEED_BACKUP_DIR=./runtime/backups
# RASEED_LICENSE_PATH=./runtime/license.json
# LICENSE_SECRET=change-me-for-production
