generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  DISABLED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  INITIAL
  ADD_STOCK
  REMOVE_STOCK
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  EXPIRED
  RETURN
  SALE
  PURCHASE
  TRANSFER_IN
  TRANSFER_OUT
}

enum CashierShiftStatus {
  OPEN
  CLOSED
}

enum InvoiceStatus {
  PAID
  VOID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
}

enum ReturnStatus {
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  RENT
  SALARIES
  ELECTRICITY
  MAINTENANCE
  DELIVERY
  SUPPLIES
  OTHER
}

model Store {
  id            String         @id @default(cuid())
  name          String
  ownerName     String?
  legalName     String?
  taxNumber     String?
  phone         String?
  email         String?
  status        StoreStatus    @default(TRIAL)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  branches      Branch[]
  users         User[]
  roles         Role[]
  categories    Category[]
  products      Product[]
  inventoryStocks InventoryStock[]
  inventoryMovements InventoryMovement[]
  inventoryBatches InventoryBatch[]
  cashierShifts CashierShift[]
  invoices Invoice[]
  invoiceItems InvoiceItem[]
  payments Payment[]
  heldOrders HeldOrder[]
  returns Return[]
  returnItems ReturnItem[]
  expenses Expense[]
  dailyClosings DailyClosing[]
  subscriptions Subscription[]
  activityLogs  ActivityLog[]

  @@index([status])
}

model Branch {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  code      String?
  address   String?
  phone     String?
  status    BranchStatus @default(ACTIVE)
  isMain    Boolean  @default(false)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  users     User[]
  inventoryStocks InventoryStock[]
  inventoryMovements InventoryMovement[]
  inventoryBatches InventoryBatch[]
  cashierShifts CashierShift[]
  invoices Invoice[]
  invoiceItems InvoiceItem[]
  payments Payment[]
  heldOrders HeldOrder[]
  returns Return[]
  returnItems ReturnItem[]
  expenses Expense[]
  dailyClosings DailyClosing[]
  activityLogs ActivityLog[]

  @@unique([storeId, name])
  @@index([storeId])
}

model User {
  id              String           @id @default(cuid())
  storeId         String?
  branchId        String?
  roleId          String?
  name            String
  email           String?
  phone           String?
  passwordHash    String?
  status          UserStatus       @default(INVITED)
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  store           Store?           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role            Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  permissions     UserPermission[]
  inventoryMovements InventoryMovement[]
  cashierShifts CashierShift[]
  invoices Invoice[]
  heldOrders HeldOrder[]
  returns Return[]
  expenses Expense[]
  dailyClosings DailyClosing[]
  activityLogs    ActivityLog[]

  @@unique([storeId, email])
  @@unique([storeId, phone])
  @@index([storeId])
  @@index([branchId])
  @@index([roleId])
}

model Role {
  id          String           @id @default(cuid())
  storeId     String?
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  store       Store?           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  description String?
  createdAt   DateTime         @default(now())
  roleLinks   RolePermission[]
  userLinks   UserPermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model Category {
  id          String        @id @default(cuid())
  storeId     String
  name        String
  description String?
  color       String?
  icon        String?
  status      CatalogStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  store       Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([status])
}

model Product {
  id            String        @id @default(cuid())
  storeId       String
  categoryId    String?
  name          String
  barcode       String?
  sku           String?
  description   String?
  imageUrl      String?
  purchasePrice Decimal       @db.Decimal(10, 2)
  sellingPrice  Decimal       @db.Decimal(10, 2)
  unitType      String
  minStock      Int           @default(0)
  expiryDate    DateTime?
  status        CatalogStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryStocks InventoryStock[]
  inventoryMovements InventoryMovement[]
  inventoryBatches InventoryBatch[]
  invoiceItems InvoiceItem[]
  returnItems ReturnItem[]

  @@unique([storeId, barcode])
  @@unique([storeId, sku])
  @@index([storeId])
  @@index([storeId, categoryId])
  @@index([status])
}

model InventoryStock {
  id               String   @id @default(cuid())
  storeId          String
  branchId         String
  productId        String
  quantity         Decimal  @default(0) @db.Decimal(14, 3)
  minStockOverride Decimal? @db.Decimal(14, 3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, branchId, productId])
  @@index([storeId])
  @@index([storeId, branchId])
  @@index([storeId, productId])
}

model InventoryMovement {
  id             String                @id @default(cuid())
  storeId        String
  branchId       String
  productId      String
  userId         String?
  type           InventoryMovementType
  quantity       Decimal               @db.Decimal(14, 3)
  quantityBefore Decimal               @db.Decimal(14, 3)
  quantityAfter  Decimal               @db.Decimal(14, 3)
  reason         String?
  referenceType  String?
  referenceId    String?
  notes          String?
  createdAt      DateTime              @default(now())
  store          Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch         Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  user           User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, branchId])
  @@index([storeId, productId])
  @@index([createdAt])
}

model InventoryBatch {
  id                String   @id @default(cuid())
  storeId           String
  branchId          String
  productId         String
  batchNumber       String?
  quantity          Decimal  @db.Decimal(14, 3)
  remainingQuantity Decimal  @db.Decimal(14, 3)
  purchasePrice     Decimal? @db.Decimal(10, 2)
  expiryDate        DateTime?
  receivedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, branchId])
  @@index([storeId, productId])
  @@index([expiryDate])
}

model CashierShift {
  id           String             @id @default(cuid())
  storeId      String
  branchId     String
  cashierId    String
  openingCash  Decimal            @db.Decimal(10, 2)
  closingCash  Decimal?           @db.Decimal(10, 2)
  expectedCash Decimal?           @db.Decimal(10, 2)
  actualCash   Decimal?           @db.Decimal(10, 2)
  difference   Decimal?           @db.Decimal(10, 2)
  status       CashierShiftStatus @default(OPEN)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch       Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashier      User               @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  returns      Return[]

  @@index([storeId, branchId])
  @@index([cashierId])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  storeId       String
  branchId      String
  cashierId     String
  shiftId       String?
  customerId    String?
  invoiceNumber String
  status        InvoiceStatus @default(PAID)
  subtotal      Decimal       @db.Decimal(10, 2)
  discountTotal Decimal       @default(0) @db.Decimal(10, 2)
  taxTotal      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paidAmount    Decimal       @db.Decimal(10, 2)
  changeAmount  Decimal       @default(0) @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashier       User          @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  shift         CashierShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items         InvoiceItem[]
  payments      Payment[]
  returns       Return[]

  @@unique([storeId, branchId, invoiceNumber])
  @@index([storeId, branchId])
  @@index([cashierId])
  @@index([shiftId])
  @@index([createdAt])
}

model InvoiceItem {
  id                    String   @id @default(cuid())
  storeId               String
  branchId              String
  invoiceId             String
  productId             String
  productName           String
  productBarcode        String?
  quantity              Decimal  @db.Decimal(14, 3)
  purchasePriceSnapshot Decimal? @db.Decimal(10, 2)
  unitPrice             Decimal  @db.Decimal(10, 2)
  discount              Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal             Decimal  @db.Decimal(10, 2)
  returnedQuantity      Decimal  @default(0) @db.Decimal(14, 3)
  createdAt             DateTime @default(now())
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch                Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice               Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product               Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  returnItems           ReturnItem[]

  @@index([storeId, branchId])
  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(cuid())
  storeId   String
  branchId  String
  invoiceId String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
  store     Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([storeId, branchId])
  @@index([invoiceId])
  @@index([method])
}

model HeldOrder {
  id        String   @id @default(cuid())
  storeId   String
  branchId  String
  cashierId String
  data      Json
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashier   User     @relation(fields: [cashierId], references: [id], onDelete: Cascade)

  @@index([storeId, branchId])
  @@index([cashierId])
}

model Return {
  id           String       @id @default(cuid())
  storeId      String
  branchId     String
  invoiceId    String
  cashierId    String
  shiftId      String?
  returnNumber String
  reason       String
  status       ReturnStatus @default(COMPLETED)
  refundTotal  Decimal      @db.Decimal(10, 2)
  refundMethod PaymentMethod
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  cashier      User         @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  shift        CashierShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items        ReturnItem[]

  @@unique([storeId, branchId, returnNumber])
  @@index([storeId, branchId])
  @@index([invoiceId])
  @@index([createdAt])
}

model ReturnItem {
  id             String   @id @default(cuid())
  storeId        String
  branchId       String
  returnId       String
  invoiceItemId  String
  productId      String
  productName    String
  productBarcode String?
  quantity       Decimal  @db.Decimal(14, 3)
  unitPrice      Decimal  @db.Decimal(10, 2)
  refundAmount   Decimal  @db.Decimal(10, 2)
  restocked      Boolean  @default(true)
  createdAt      DateTime @default(now())
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  return         Return   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  invoiceItem    InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Restrict)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([storeId, branchId])
  @@index([returnId])
  @@index([invoiceItemId])
  @@index([productId])
}

model Expense {
  id            String          @id @default(cuid())
  storeId       String
  branchId      String
  userId        String
  title         String
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(10, 2)
  expenseDate   DateTime
  notes         String?
  attachmentUrl String?
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  store         Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([storeId, branchId])
  @@index([expenseDate])
  @@index([category])
  @@index([deletedAt])
}

model DailyClosing {
  id             String   @id @default(cuid())
  storeId        String
  branchId       String
  closedById     String
  date           DateTime
  totalSales     Decimal  @db.Decimal(10, 2)
  totalReturns   Decimal  @db.Decimal(10, 2)
  totalExpenses  Decimal  @db.Decimal(10, 2)
  cashPayments   Decimal  @db.Decimal(10, 2)
  cardPayments   Decimal  @db.Decimal(10, 2)
  walletPayments Decimal  @db.Decimal(10, 2)
  openingCash    Decimal  @db.Decimal(10, 2)
  expectedCash   Decimal  @db.Decimal(10, 2)
  actualCash     Decimal  @db.Decimal(10, 2)
  difference     Decimal  @db.Decimal(10, 2)
  netTotal       Decimal  @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  closedBy       User     @relation(fields: [closedById], references: [id], onDelete: Restrict)

  @@unique([storeId, branchId, date])
  @@index([storeId, branchId])
  @@index([date])
}

model SubscriptionPlan {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  monthlyPrice  Decimal        @db.Decimal(10, 2)
  maxBranches   Int?
  maxUsers      Int?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  storeId   String
  planId    String
  status    SubscriptionStatus @default(TRIAL)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  store     Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([storeId])
  @@index([planId])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  storeId   String?
  branchId  String?
  userId    String?
  action    String
  entityType String?
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([branchId])
  @@index([userId])
}
